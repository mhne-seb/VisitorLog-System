<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Visitor Log System</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <style>
        :root {
            --primary:       #1e40af;
            --primary-light: #3b82f6;
            --primary-dark:  #1e3a8a;
            --accent:        #06b6d4;
            --success:       #10b981;
            --danger:        #ef4444;
            --warning:       #f59e0b;
            --bg:            #f0f4f8;
            --card-bg:       #ffffff;
            --text-main:     #1e293b;
            --text-muted:    #64748b;
            --border:        #e2e8f0;
            --shadow-sm:     0 1px 3px rgba(0,0,0,.07), 0 1px 2px rgba(0,0,0,.05);
            --shadow-md:     0 4px 16px rgba(30,64,175,.10);
            --shadow-lg:     0 10px 40px rgba(30,64,175,.14);
            --radius:        14px;
            --radius-sm:     8px;
        }

        * { box-sizing: border-box; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: var(--bg);
            color: var(--text-main);
            min-height: 100vh;
        }

        /* ── TOPBAR ─────────────────────────────────── */
        .topbar {
            background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 60%, var(--primary-light) 100%);
            padding: 0 2rem;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 2px 12px rgba(30,64,175,.3);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .topbar-brand {
            display: flex;
            align-items: center;
            gap: .75rem;
            color: #fff;
            text-decoration: none;
        }

        .topbar-brand .brand-icon {
            width: 38px; height: 38px;
            background: rgba(255,255,255,.18);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.2rem;
            backdrop-filter: blur(4px);
        }

        .topbar-brand .brand-name {
            font-size: 1.1rem;
            font-weight: 700;
            letter-spacing: -.3px;
        }

        .topbar-brand .brand-sub {
            font-size: .72rem;
            opacity: .75;
            font-weight: 500;
            letter-spacing: .5px;
            text-transform: uppercase;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .admin-badge {
            display: flex;
            align-items: center;
            gap: .5rem;
            background: rgba(255,255,255,.15);
            color: #fff;
            padding: .35rem .85rem;
            border-radius: 50px;
            font-size: .82rem;
            font-weight: 600;
            backdrop-filter: blur(4px);
        }

        .btn-logout {
            background: rgba(255,255,255,.15);
            border: 1px solid rgba(255,255,255,.3);
            color: #fff;
            padding: .38rem .9rem;
            border-radius: 8px;
            font-size: .82rem;
            font-weight: 600;
            cursor: pointer;
            transition: all .2s;
            display: flex; align-items: center; gap: .4rem;
        }

        .btn-logout:hover {
            background: rgba(255,255,255,.28);
            border-color: rgba(255,255,255,.5);
        }

        /* ── MAIN CONTENT ───────────────────────────── */
        .main-content {
            padding: 2rem 1.5rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        /* ── CARDS ──────────────────────────────────── */
        .panel-card {
            background: var(--card-bg);
            border-radius: var(--radius);
            box-shadow: var(--shadow-md);
            border: 1px solid var(--border);
            overflow: hidden;
        }

        .panel-header {
            background: linear-gradient(135deg, #f8faff 0%, #eef2ff 100%);
            border-bottom: 1px solid var(--border);
            padding: 1.1rem 1.5rem;
            display: flex;
            align-items: center;
            gap: .75rem;
        }

        .panel-header-icon {
            width: 36px; height: 36px;
            border-radius: 9px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem;
        }

        .panel-header-icon.blue { background: #dbeafe; color: var(--primary); }
        .panel-header-icon.cyan { background: #cffafe; color: #0891b2; }

        .panel-header h5 {
            font-size: .95rem;
            font-weight: 700;
            margin: 0;
            color: var(--text-main);
        }

        .panel-header span {
            font-size: .78rem;
            color: var(--text-muted);
            font-weight: 500;
        }

        .panel-body { padding: 1.5rem; }

        /* ── FORM STYLES ────────────────────────────── */
        .form-label {
            font-size: .8rem;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: .5px;
            margin-bottom: .35rem;
        }

        .form-control, .form-select {
            border: 1.5px solid var(--border);
            border-radius: var(--radius-sm);
            padding: .55rem .85rem;
            font-size: .88rem;
            color: var(--text-main);
            transition: border-color .2s, box-shadow .2s;
            font-family: inherit;
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--primary-light);
            box-shadow: 0 0 0 3px rgba(59,130,246,.12);
            outline: none;
        }

        .form-control.is-invalid { border-color: var(--danger); }
        .invalid-feedback { font-size: .78rem; }

        .input-group-text {
            background: #f8faff;
            border: 1.5px solid var(--border);
            color: var(--text-muted);
            font-size: .9rem;
        }

        /* ── BUTTONS ────────────────────────────────── */
        .btn-primary-custom {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            padding: .58rem 1.4rem;
            font-size: .88rem;
            font-weight: 700;
            cursor: pointer;
            transition: all .2s;
            display: inline-flex; align-items: center; gap: .45rem;
            box-shadow: 0 2px 8px rgba(30,64,175,.25);
        }

        .btn-primary-custom:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 14px rgba(30,64,175,.35);
            color: #fff;
        }

        .btn-primary-custom:active { transform: translateY(0); }

        .btn-icon {
            width: 32px; height: 32px;
            border-radius: 7px;
            display: inline-flex; align-items: center; justify-content: center;
            font-size: .85rem;
            border: none;
            cursor: pointer;
            transition: all .18s;
        }

        .btn-icon.edit   { background: #dbeafe; color: var(--primary); }
        .btn-icon.delete { background: #fee2e2; color: var(--danger); }
        .btn-icon.edit:hover   { background: var(--primary); color: #fff; }
        .btn-icon.delete:hover { background: var(--danger); color: #fff; }

        /* ── SEARCH BAR ─────────────────────────────── */
        .search-wrapper {
            position: relative;
            max-width: 340px;
        }

        .search-wrapper .bi-search {
            position: absolute;
            left: .85rem; top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: .85rem;
            pointer-events: none;
        }

        .search-wrapper input {
            padding-left: 2.4rem !important;
        }

        /* ── TABLE ──────────────────────────────────── */
        .visitors-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            font-size: .84rem;
        }

        .visitors-table thead tr {
            background: linear-gradient(135deg, #f8faff 0%, #eef2ff 100%);
        }

        .visitors-table thead th {
            padding: .75rem 1rem;
            font-size: .73rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .6px;
            color: var(--text-muted);
            border-bottom: 2px solid var(--border);
            white-space: nowrap;
        }

        .visitors-table tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background .15s;
        }

        .visitors-table tbody tr:last-child { border-bottom: none; }
        .visitors-table tbody tr:hover { background: #f8faff; }

        .visitors-table tbody td {
            padding: .85rem 1rem;
            color: var(--text-main);
            vertical-align: middle;
        }

        .visitor-name {
            font-weight: 700;
            color: var(--primary);
        }

        .badge-purpose {
            background: #eff6ff;
            color: var(--primary);
            border-radius: 6px;
            padding: .25rem .65rem;
            font-size: .75rem;
            font-weight: 600;
        }

        .visitor-id {
            width: 30px; height: 30px;
            border-radius: 8px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
            color: #fff;
            display: flex; align-items: center; justify-content: center;
            font-size: .75rem;
            font-weight: 700;
        }

        /* ── ALERTS ─────────────────────────────────── */
        .alert-custom {
            border-radius: var(--radius-sm);
            padding: .85rem 1.1rem;
            font-size: .85rem;
            font-weight: 500;
            display: flex; align-items: center; gap: .65rem;
            border: none;
        }

        .alert-success-custom {
            background: #d1fae5;
            color: #065f46;
        }

        .alert-error-custom {
            background: #fee2e2;
            color: #991b1b;
        }

        /* ── EMPTY STATE ────────────────────────────── */
        .empty-state {
            text-align: center;
            padding: 3.5rem 1rem;
        }

        .empty-state .empty-icon {
            font-size: 3.5rem;
            color: #cbd5e1;
            margin-bottom: 1rem;
        }

        .empty-state h6 {
            color: var(--text-muted);
            font-weight: 600;
            margin-bottom: .35rem;
        }

        .empty-state p {
            color: #94a3b8;
            font-size: .85rem;
            margin: 0;
        }

        /* ── STATS BAR ──────────────────────────────── */
        .stat-chip {
            background: #eff6ff;
            border: 1.5px solid #bfdbfe;
            border-radius: 8px;
            padding: .4rem .85rem;
            font-size: .8rem;
            font-weight: 700;
            color: var(--primary);
            display: inline-flex; align-items: center; gap: .4rem;
        }

        /* ── MODAL ──────────────────────────────────── */
        .modal-content {
            border: none;
            border-radius: var(--radius);
            box-shadow: var(--shadow-lg);
        }

        .modal-header {
            background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 100%);
            color: #fff;
            border-radius: var(--radius) var(--radius) 0 0;
            padding: 1.1rem 1.5rem;
        }

        .modal-header .btn-close {
            filter: brightness(0) invert(1);
            opacity: .8;
        }

        .modal-title { font-size: .95rem; font-weight: 700; }
        .modal-body { padding: 1.5rem; }
        .modal-footer {
            border-top: 1px solid var(--border);
            padding: 1rem 1.5rem;
        }

        /* ── SECTION DIVIDER ────────────────────────── */
        .section-gap { margin-top: 1.75rem; }

        /* ── RESPONSIVE ─────────────────────────────── */
        @@media (max-width: 768px) {
            .topbar { padding: 0 1rem; }
            .brand-name { font-size: .95rem; }
            .main-content { padding: 1.25rem .75rem; }
            .panel-body { padding: 1rem; }
            .visitors-table { font-size: .78rem; }
            .visitors-table thead th,
            .visitors-table tbody td { padding: .65rem .75rem; }
        }

        /* ── SCROLLABLE TABLE ───────────────────────── */
        .table-responsive-custom {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        /* ── FADE IN ────────────────────────────────── */
        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(16px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .fade-up { animation: fadeUp .35s ease both; }
        .fade-up-2 { animation: fadeUp .35s .1s ease both; }
    </style>
</head>
<body>

    @if (Context.Session.GetString("IsAuthenticated") == "true")
    {
        <!-- ── TOPBAR ── -->
        <nav class="topbar">
            <a class="topbar-brand" href="#">
                <div class="brand-icon"><i class="bi bi-person-badge-fill"></i></div>
                <div>
                    <div class="brand-name">Visitor Log System</div>
                    <div class="brand-sub">Admin Dashboard</div>
                </div>
            </a>
            <div class="topbar-right">
                <div class="admin-badge">
                    <i class="bi bi-shield-fill-check"></i>
                    <span>@Context.Session.GetString("AdminUsername")</span>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-logout">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </button>
                </form>
            </div>
        </nav>
    }

    <div class="@(Context.Session.GetString("IsAuthenticated") == "true" ? "main-content" : "")">
        @RenderBody()
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
